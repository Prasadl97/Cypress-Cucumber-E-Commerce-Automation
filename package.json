{
  "name": "cypress-cucumber",
  "version": "1.0.0",
  "description": "E2E tests with Cypress and Cucumber BDD",
  "type": "module",
  "scripts": {
    "test": "cypress run",
    "test:headed": "cypress run --headed",
    "test:open": "cypress open",
    "test:smoke": "cypress run --env tags=@smoke",
    "test:admin": "cypress run --env tags=@admin",
    "test:admin:headed": "cypress run --browser firefox --headed --env tags=@admin",
    "test:cart": "cypress run --env tags=@cart",
    "test:registration": "cypress run --env tags=@registration"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^22.0.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.3",
    "@types/node": "^22.0.0",
    "cypress": "^13.15.0",
    "cypress-split": "^1.14.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
